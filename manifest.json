{
  "manifest_version": 3,
  "name": "Google Ads Grader — by Improve My Ads",
  "short_name": "Google Ads Grader",
  "version": "1.1.0",
  "description": "Grade any Google Ads headline instantly against real Google Ads factors — query intent, CTAs, extensions. Get a button on every Google search ad, or right-click any text — free, no sign-in.",
  "homepage_url": "https://improve-my-ads.com/extension",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Improve My Ads — Google Ads Grader"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["contextMenus", "scripting", "activeTab"],
  "host_permissions": [
    "https://fmuaeuzxpxhqociziebs.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.co.uk/search*",
        "https://www.google.ca/search*",
        "https://www.google.com.au/search*",
        "https://www.google.de/search*",
        "https://www.google.fr/search*",
        "https://www.google.es/search*",
        "https://www.google.it/search*",
        "https://www.google.co.in/search*",
        "https://www.google.com.br/search*"
      ],
      "js": ["content/ad-detector.js"],
      "run_at": "document_idle"
    }
  ],
  "minimum_chrome_version": "110"
}
